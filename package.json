{
    "name":  "open-fireside",
    "private":  true,
    "version":  "0.4.0",
    "main":  "dist-electron/main/index.js",
    "scripts":  {
                    "dev":  "vite",
                    "dev:renderer":  "vite",
                    "dev:electron":  "npm run build:electron \u0026\u0026 wait-on tcp:5173 \u0026\u0026 set OPEN_FIRESIDE_DEV_SERVER_URL=http://127.0.0.1:5173 \u0026\u0026 electron .",
                    "dev:desktop":  "npm-run-all -p dev:renderer dev:electron:watch",
                    "dev:electron:watch":  "nodemon --watch electron --ext ts --exec \"npm run dev:electron\"",
                    "build":  "vite build \u0026\u0026 npm run build:electron",
                    "build:electron":  "tsc -p tsconfig.main.json \u0026\u0026 tsc -p tsconfig.preload.json",
                    "preview":  "vite preview",
                    "start":  "electron .",
                    "db:migrate":  "tsx electron/main/db/run-migrations.ts",
                    "db:seed":  "tsx electron/main/db/seed.ts",
                    "pack:win":  "npm run build \u0026\u0026 electron-builder --win"
                },
    "dependencies":  {
                         "@tanstack/react-query":  "^5.83.0",
                         "better-sqlite3":  "^12.8.0",
                         "drizzle-orm":  "^0.44.2",
                         "leaflet":  "^1.9.4",
                         "react":  "^18.3.1",
                         "react-dom":  "^18.3.1",
                         "zustand":  "^5.0.8",
                         "playwright-core":  "^1.54.2"
                     },
    "devDependencies":  {
                            "@types/better-sqlite3":  "^7.6.12",
                            "@types/leaflet":  "^1.9.21",
                            "@types/node":  "^24.3.0",
                            "@types/react":  "^18.3.23",
                            "@types/react-dom":  "^18.3.7",
                            "drizzle-kit":  "^0.31.4",
                            "electron":  "^35.2.0",
                            "electron-builder":  "^25.1.8",
                            "nodemon":  "^3.1.10",
                            "npm-run-all":  "^4.1.5",
                            "tsx":  "^4.20.5",
                            "typescript":  "^5.9.2",
                            "vite":  "^5.4.10",
                            "wait-on":  "^8.0.3"
                        }
}
