<Window x:Class="OpenFireside.Desktop.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
        xmlns:viewModels="clr-namespace:OpenFireside.Desktop.ViewModels"
        xmlns:views="clr-namespace:OpenFireside.Desktop.Views"
        xmlns:converters="clr-namespace:OpenFireside.Desktop.Converters"
        mc:Ignorable="d"
        Title="Open Fireside v2"
        Height="920"
        Width="1440"
        MinHeight="760"
        MinWidth="1180"
        Background="#07111F">
    <Window.Resources>
        <converters:BooleanToGridLengthConverter x:Key="BooleanToGridLengthConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:IncidentsViewModel}">
            <views:IncidentsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:IncidentDetailViewModel}">
            <views:IncidentDetailView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:MapsViewModel}">
            <views:MapsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding IsSidebarCollapsed, Converter={StaticResource BooleanToGridLengthConverter}}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0D7C92">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="16,18,16,10">
                    <DockPanel LastChildFill="False">
                        <svg:SvgViewbox Width="36" Height="36" Source="{Binding BrandIconAssetPath}" Stretch="Uniform" />
                        <Button DockPanel.Dock="Right"
                                Width="40"
                                Height="40"
                                Margin="12,0,0,0"
                                Command="{Binding ToggleSidebarCommand}"
                                Background="#114F63"
                                BorderBrush="{x:Null}"
                                ToolTip="Toggle sidebar">
                            <svg:SvgViewbox Width="18" Height="18" Source="{Binding SidebarToggleAssetPath}" Stretch="Uniform" />
                        </Button>
                    </DockPanel>
                    <TextBlock Margin="0,12,0,0"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="18"
                               Text="Open Fireside v2">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <StackPanel Margin="12,8,12,16">
                    <ItemsControl ItemsSource="{Binding NavigationItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,0,10"
                                        Padding="14,12"
                                        Background="#114F63"
                                        Foreground="White"
                                        BorderBrush="{x:Null}"
                                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Target}">
                                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="#F4F7FC" CornerRadius="20" Padding="22" Margin="0,0,0,18">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="{Binding CurrentTitle}" FontSize="34" FontWeight="Bold" Foreground="#122033" />
                        <TextBlock Margin="0,6,0,0" Text="{Binding HeaderStatus}" Foreground="#4B6076"/>
                    </StackPanel>
                    <Button DockPanel.Dock="Right"
                            Padding="18,12"
                            Background="#122033"
                            Foreground="White"
                            BorderBrush="{x:Null}"
                            Command="{Binding OpenCurrentInNewWindowCommand}">
                        <TextBlock Text="Open in new window" />
                    </Button>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Background="#F8FAFD" CornerRadius="24" Padding="26">
                <ContentControl Content="{Binding CurrentWorkspace}" />
            </Border>
        </Grid>
    </Grid>
</Window>
