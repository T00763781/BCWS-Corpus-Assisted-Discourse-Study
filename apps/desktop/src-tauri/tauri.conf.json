{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Open Fireside",
  "version": "0.1.0",
  "identifier": "com.openfireside.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Open Fireside",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi"]
  }
}
